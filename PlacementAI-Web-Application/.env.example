# ============================================================
# IBM watsonx.ai / IBM Cloud Deployment Configuration
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to source control.

# IBM Cloud IAM API Key
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM watsonx.ai AutoAI Deployment Endpoint URL
IBM_DEPLOYMENT_URL=https://us-south.ml.cloud.ibm.com/ml/v4/deployments/your_deployment_id/predictions?version=2021-05-01

# IBM Watson Machine Learning Instance ID
IBM_ML_INSTANCE_ID=your_wml_instance_id_here

# IBM IAM Token URL (default, change only if using a different region)
IBM_IAM_TOKEN_URL=https://iam.cloud.ibm.com/identity/token

# Server Configuration
PORT=3000
NODE_ENV=development
